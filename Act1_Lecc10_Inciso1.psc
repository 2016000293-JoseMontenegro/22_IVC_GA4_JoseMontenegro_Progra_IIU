//PSEint
Algoritmo Lecc10_Act1_Inc1
	Definir i Como Entero
	
	Escribir "-------CUPONERA DE BARBERÍA DON CRUP-------"
	
	Para i=1 Hasta 8 Con Paso 1 Hacer
		Escribir "Presione una tecla para marcar el sello número ",i
		Esperar Tecla
		Escribir "¡SELLO  ",i, " MARCADO!"
		Escribir "--------------------------------------"
	Fin Para
	Escribir "¡Felicidades! Has completado los 8 sellos"
	Escribir "CORTE GRATIS!!!"
FinAlgoritmo
